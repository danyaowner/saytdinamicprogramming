#!/usr/bin/env python3
"""
Генерация курсовой работы на тему:
«Оптимизация распределения дизайнерских ресурсов и графических проектов
методом динамического программирования»
"""

from docx import Document
from docx.shared import Pt, Cm, Inches
from docx.enum.text import WD_ALIGN_PARAGRAPH
from docx.oxml.ns import qn, nsdecls
from docx.oxml import parse_xml, OxmlElement
import os

doc = Document()

# ─── Стили по умолчанию ───────────────────────────────────────────────
style = doc.styles['Normal']
font = style.font
font.name = 'Times New Roman'
font.size = Pt(14)
style.paragraph_format.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
style.paragraph_format.first_line_indent = Cm(1.25)
style.paragraph_format.line_spacing = 1.5
style.paragraph_format.space_before = Pt(0)
style.paragraph_format.space_after = Pt(0)

# Настройка стиля заголовков
for i in range(1, 4):
    h_style = doc.styles[f'Heading {i}']
    h_font = h_style.font
    h_font.name = 'Times New Roman'
    h_font.size = Pt(14)
    h_font.bold = True
    h_font.color.rgb = None
    h_style.paragraph_format.alignment = WD_ALIGN_PARAGRAPH.LEFT
    h_style.paragraph_format.first_line_indent = Cm(0)
    h_style.paragraph_format.line_spacing = 1.5
    h_style.paragraph_format.space_before = Pt(0)
    h_style.paragraph_format.space_after = Pt(0)

page_width = Cm(21.0)
page_height = Cm(29.7)
for section in doc.sections:
    section.page_width = page_width
    section.page_height = page_height
    section.top_margin = Cm(2.0)
    section.bottom_margin = Cm(2.0)
    section.left_margin = Cm(3.0)
    section.right_margin = Cm(1.5)

# ─── Вспомогательные функции ──────────────────────────────────────────

def add_paragraph(text, bold=False, alignment=None, indent=True, size=14,
                  spacing_before=0, spacing_after=0):
    p = doc.add_paragraph()
    if alignment is not None:
        p.alignment = alignment
    else:
        p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    pf = p.paragraph_format
    pf.first_line_indent = Cm(1.25) if indent else Cm(0)
    pf.line_spacing = 1.5
    pf.space_before = Pt(spacing_before)
    pf.space_after = Pt(spacing_after)
    run = p.add_run(text)
    run.font.name = 'Times New Roman'
    run.font.size = Pt(size)
    run.bold = bold
    return p

def add_section_title(number, title):
    p = doc.add_paragraph()
    p.style = doc.styles['Heading 1']
    p.alignment = WD_ALIGN_PARAGRAPH.LEFT
    pf = p.paragraph_format
    pf.first_line_indent = Cm(0)
    pf.line_spacing = 1.5
    pf.space_before = Pt(0)
    pf.space_after = Pt(0)
    pf.page_break_before = True
    prefix = f'{number} ' if number else ''
    run = p.add_run(f'{prefix}{title}')
    run.font.name = 'Times New Roman'
    run.font.size = Pt(14)
    run.bold = True
    return p

def add_subsection_title(number, title):
    p = doc.add_paragraph()
    p.style = doc.styles['Heading 2']
    p.alignment = WD_ALIGN_PARAGRAPH.LEFT
    pf = p.paragraph_format
    pf.first_line_indent = Cm(0)
    pf.line_spacing = 1.5
    pf.space_before = Pt(14)
    pf.space_after = Pt(0)
    run = p.add_run(f'{number} {title}')
    run.font.name = 'Times New Roman'
    run.font.size = Pt(14)
    run.bold = True
    return p

def add_empty_line():
    p = doc.add_paragraph()
    pf = p.paragraph_format
    pf.first_line_indent = Cm(0)
    pf.line_spacing = 1.5
    pf.space_before = Pt(0)
    pf.space_after = Pt(0)
    run = p.add_run('')
    run.font.name = 'Times New Roman'
    run.font.size = Pt(14)
    return p

def add_body(text):
    return add_paragraph(text)

def add_bullet(text):
    p = doc.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    pf = p.paragraph_format
    pf.first_line_indent = Cm(1.25)
    pf.line_spacing = 1.5
    pf.space_before = Pt(0)
    pf.space_after = Pt(0)
    run = p.add_run(f'- {text}')
    run.font.name = 'Times New Roman'
    run.font.size = Pt(14)
    return p

def add_centered(text, bold=False, size=14):
    return add_paragraph(text, bold=bold, alignment=WD_ALIGN_PARAGRAPH.CENTER,
                         indent=False, size=size)

def add_right(text, bold=False, size=14):
    return add_paragraph(text, bold=bold, alignment=WD_ALIGN_PARAGRAPH.RIGHT,
                         indent=False, size=size)

def add_formula_numbered(formula_text, number):
    p = doc.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    pf = p.paragraph_format
    pf.first_line_indent = Cm(0)
    pf.line_spacing = 1.5
    pf.space_before = Pt(6)
    pf.space_after = Pt(6)
    run = p.add_run(formula_text)
    run.font.name = 'Times New Roman'
    run.font.size = Pt(14)
    run.italic = True
    run2 = p.add_run(f'    ({number})')
    run2.font.name = 'Times New Roman'
    run2.font.size = Pt(14)
    return p

def set_cell_text(cell, text, bold=False, size=12, alignment=WD_ALIGN_PARAGRAPH.CENTER):
    cell.text = ''
    p = cell.paragraphs[0]
    p.alignment = alignment
    pf = p.paragraph_format
    pf.first_line_indent = Cm(0)
    pf.line_spacing = 1.0
    pf.space_before = Pt(2)
    pf.space_after = Pt(2)
    run = p.add_run(text)
    run.font.name = 'Times New Roman'
    run.font.size = Pt(size)
    run.bold = bold

def add_table(headers, rows, caption=None):
    if caption:
        p = doc.add_paragraph()
        p.alignment = WD_ALIGN_PARAGRAPH.CENTER
        pf = p.paragraph_format
        pf.first_line_indent = Cm(0)
        pf.line_spacing = 1.5
        pf.space_before = Pt(6)
        pf.space_after = Pt(3)
        run = p.add_run(caption)
        run.font.name = 'Times New Roman'
        run.font.size = Pt(12)
        run.bold = True
    table = doc.add_table(rows=1 + len(rows), cols=len(headers))
    table.style = 'Table Grid'
    for i, h in enumerate(headers):
        set_cell_text(table.rows[0].cells[i], h, bold=True, size=11)
    for r_idx, row in enumerate(rows):
        for c_idx, val in enumerate(row):
            set_cell_text(table.rows[r_idx + 1].cells[c_idx], str(val), size=11)
    return table

def add_page_break():
    doc.add_page_break()


# ════════════════════════════════════════════════════════════════════════
# ТИТУЛЬНЫЙ ЛИСТ
# ════════════════════════════════════════════════════════════════════════

for _ in range(6):
    add_empty_line()

add_centered('МИНИСТЕРСТВО НАУКИ И ВЫСШЕГО ОБРАЗОВАНИЯ РОССИЙСКОЙ ФЕДЕРАЦИИ', bold=True, size=12)
add_empty_line()
add_centered('Федеральное государственное автономное образовательное учреждение\nвысшего образования', size=12)
add_centered('«РОССИЙСКИЙ УНИВЕРСИТЕТ ДРУЖБЫ НАРОДОВ»', bold=True, size=12)
add_empty_line()
add_centered('Институт _________________________', size=12)
add_centered('Кафедра _________________________', size=12)
add_empty_line()
add_empty_line()
add_centered('КУРСОВОЙ ПРОЕКТ', bold=True, size=16)
add_empty_line()
add_centered('по дисциплине «Теория принятия решений»', size=14)
add_empty_line()
add_centered('на тему:', size=14)
add_centered('«ОПТИМИЗАЦИЯ РАСПРЕДЕЛЕНИЯ ДИЗАЙНЕРСКИХ РЕСУРСОВ\nИ ГРАФИЧЕСКИХ ПРОЕКТОВ МЕТОДОМ ДИНАМИЧЕСКОГО\nПРОГРАММИРОВАНИЯ»', bold=True, size=14)
add_empty_line()
add_empty_line()
add_empty_line()

add_right('Выполнил:')
add_right('студент группы ________')
add_right('___________________')
add_right('(подпись)')
add_empty_line()
add_right('Проверил:')
add_right('___________________')
add_right('(должность, ФИО)')
add_empty_line()
add_empty_line()
add_empty_line()
add_centered('Москва, 2026', size=14)

add_page_break()

# ════════════════════════════════════════════════════════════════════════
# ОГЛАВЛЕНИЕ (автоматическое поле TOC)
# ════════════════════════════════════════════════════════════════════════

p = doc.add_paragraph()
p.alignment = WD_ALIGN_PARAGRAPH.LEFT
pf = p.paragraph_format
pf.first_line_indent = Cm(0)
pf.line_spacing = 1.5
pf.space_before = Pt(0)
pf.space_after = Pt(0)
run = p.add_run('ОГЛАВЛЕНИЕ')
run.font.name = 'Times New Roman'
run.font.size = Pt(14)
run.bold = True

add_empty_line()

# Вставка поля TOC (Table of Contents)
p_toc = doc.add_paragraph()
p_toc.alignment = WD_ALIGN_PARAGRAPH.LEFT
pf_toc = p_toc.paragraph_format
pf_toc.first_line_indent = Cm(0)
pf_toc.line_spacing = 1.5
pf_toc.space_before = Pt(0)
pf_toc.space_after = Pt(0)

# Создаём поле TOC через XML
fld_begin = OxmlElement('w:fldChar')
fld_begin.set(qn('w:fldCharType'), 'begin')
run1 = p_toc.add_run()
run1._r.append(fld_begin)

instr = OxmlElement('w:instrText')
instr.set(qn('xml:space'), 'preserve')
instr.text = ' TOC \\o "1-2" \\h \\z \\u '
run2 = p_toc.add_run()
run2._r.append(instr)

fld_sep = OxmlElement('w:fldChar')
fld_sep.set(qn('w:fldCharType'), 'separate')
run3 = p_toc.add_run()
run3._r.append(fld_sep)

run4 = p_toc.add_run('[Для обновления оглавления: правый клик → «Обновить поле»]')
run4.font.name = 'Times New Roman'
run4.font.size = Pt(12)
run4.font.color.rgb = None
run4.italic = True

fld_end = OxmlElement('w:fldChar')
fld_end.set(qn('w:fldCharType'), 'end')
run5 = p_toc.add_run()
run5._r.append(fld_end)

add_page_break()


# ════════════════════════════════════════════════════════════════════════
# ВВЕДЕНИЕ
# ════════════════════════════════════════════════════════════════════════

add_section_title('', 'ВВЕДЕНИЕ')

add_body(
    'В современных условиях рыночной экономики и высокой конкуренции в сфере '
    'дизайна и графических услуг эффективное управление ресурсами становится '
    'одним из ключевых факторов успеха дизайн-студий, рекламных агентств и '
    'корпоративных отделов дизайна. Каждый проект требует определённого набора '
    'компетенций, временных затрат и количества специалистов, при этом ресурсы '
    'организации всегда ограничены. Задача оптимального распределения дизайнеров '
    'между параллельно выполняемыми графическими проектами представляет собой '
    'актуальную проблему теории принятия решений и исследования операций.'
)

add_body(
    'Актуальность темы обусловлена ростом объёмов проектной работы в дизайн-'
    'индустрии, необходимостью минимизации простоев специалистов и повышения '
    'эффективности использования трудовых ресурсов. Метод динамического '
    'программирования, разработанный Ричардом Беллманом в 1950-х годах, '
    'является мощным инструментом для решения многошаговых задач оптимизации. '
    'Он позволяет разбить исходную сложную задачу на последовательность более '
    'простых подзадач и найти оптимальное решение на основе принципа '
    'оптимальности Беллмана.'
)

add_body(
    'Объектом исследования в данной работе является процесс распределения '
    'дизайнерских ресурсов при выполнении графических проектов в условиях '
    'ограниченных временных и трудовых ресурсов. Предметом исследования '
    'выступают методы оптимизации распределения ресурсов, в частности метод '
    'динамического программирования.'
)

add_body(
    'Цель курсового проекта — разработка математической модели и программного '
    'обеспечения для оптимизации распределения дизайнеров между графическими '
    'проектами на основе метода динамического программирования, а также '
    'апробация разработанного решения на примере практической задачи.'
)

add_body('Для достижения поставленной цели необходимо решить следующие задачи:')

add_bullet('провести анализ предметной области и методов распределения ресурсов;')
add_bullet('изучить теоретические основы метода динамического программирования;')
add_bullet('разработать математическую модель задачи распределения дизайнеров;')
add_bullet('реализовать алгоритм динамического программирования в виде программного обеспечения;')
add_bullet('выполнить ручной расчёт и программное решение практического примера;')
add_bullet('провести сравнительный анализ результатов, полученных различными способами;')
add_bullet('оценить эффективность применения метода динамического программирования для решения поставленной задачи.')

add_body(
    'В работе используются следующие методы исследования: анализ научно-'
    'технической литературы, математическое моделирование, метод динамического '
    'программирования, численные методы оптимизации, экспериментальное '
    'тестирование программного обеспечения.'
)

add_body(
    'Практическая значимость работы заключается в возможности применения '
    'разработанного программного обеспечения в деятельности дизайн-студий и '
    'рекламных агентств для повышения эффективности планирования загрузки '
    'сотрудников и сокращения сроков выполнения проектов.'
)

add_page_break()


