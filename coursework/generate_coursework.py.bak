add_section_title('3', 'ПРОГРАММНАЯ РЕАЛИЗАЦИЯ И РЕШЕНИЕ ЗАДАЧИ')

# --- 3.1 ---
add_subsection_title('3.1', 'Разработка программного обеспечения')

add_body(
    'Для решения задачи распределения дизайнерских ресурсов методом '
    'динамического программирования разработано программное обеспечение '
    'на языке Python. Выбор языка Python обусловлен его широкими '
    'возможностями для научных и инженерных расчётов, наличием развитых '
    'библиотек для математических операций, а также простотой и наглядностью '
    'синтаксиса, что облегчает понимание алгоритма.'
)

add_body(
    'Программа реализует алгоритм динамического программирования, описанный '
    'в разделе 2.3, и предоставляет интерфейс командной строки для ввода '
    'исходных данных и вывода результатов. Основные функциональные '
    'возможности программы:'
)

add_bullet('ввод количества проектов и доступного количества дизайнеров;')
add_bullet('ввод или генерация таблиц эффективности для каждого проекта;')
add_bullet('вычисление оптимального распределения методом динамического программирования;')
add_bullet('вывод таблиц функций Беллмана;')
add_bullet('вывод оптимального решения и суммарной эффективности;')
add_bullet('визуализация результатов в виде таблиц.')

add_body(
    'Архитектура программы включает следующие модули:'
)

add_bullet('dp_optimizer.py — основной модуль, реализующий алгоритм '
           'динамического программирования (класс DPOptimizer);')
add_bullet('main.py — точка входа, обеспечивающая ввод данных и вывод '
           'результатов.')

add_body(
    'Опишем структуру основного класса DPOptimizer. Класс содержит методы:'
)

add_bullet('__init__(self, n_projects, total_resources, efficiency_table) — '
           'конструктор, принимающий количество проектов, общее количество '
           'ресурсов и таблицу эффективности;')
add_bullet('solve(self) — основной метод, выполняющий прямой и обратный '
