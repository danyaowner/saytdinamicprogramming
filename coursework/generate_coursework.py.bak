add_empty_line()

code_text = """import numpy as np

class DPOptimizer:
    \"\"\"Решение задачи распределения ресурсов
    методом динамического программирования.\"\"\"

    def __init__(self, n_projects, total_resources, efficiency_table):
        self.n = n_projects
        self.R = total_resources
        self.f = efficiency_table
        self.F = [[0.0] * (self.R + 1) for _ in range(self.n + 2)]
        self.x_opt = [[0] * (self.R + 1) for _ in range(self.n + 2)]

    def solve(self):
        self._forward_pass()
        distribution = self._backward_pass()
        return distribution, self.F[1][self.R]

    def _forward_pass(self):
        # Граничное условие: F_{N+1}(s) = 0
        for s in range(self.R + 1):
            self.F[self.n + 1][s] = 0.0

        for k in range(self.n, 0, -1):
            for s in range(self.R + 1):
                best_value = -1.0
                best_x = 0
                for x in range(s + 1):
                    value = (self.f[k - 1][x]
                             + self.F[k + 1][s - x])
                    if value > best_value:
                        best_value = value
                        best_x = x
                self.F[k][s] = best_value
                self.x_opt[k][s] = best_x

    def _backward_pass(self):
        distribution = []
        s = self.R
        for k in range(1, self.n + 1):
            x = self.x_opt[k][s]
            distribution.append(x)
            s -= x
        return distribution

    def print_results(self):
        distribution, total = self.solve()
        print(\"Оптимальное распределение:\")
        for i, x in enumerate(distribution, 1):
            print(f\"  Проект {i}: {x} дизайнеров, \"
                  f\"эффективность: {self.f[i-1][x]}\")
        print(f\"Максимальная суммарная эффективность: {total}\")


def main():
    n_projects = 3
    total_resources = 5
    efficiency = [
        [0, 120, 210, 280, 340, 390],
        [0, 100, 190, 265, 330, 380],
        [0,  90, 170, 240, 300, 350],
    ]
    optimizer = DPOptimizer(n_projects, total_resources, efficiency)
    optimizer.print_results()


if __name__ == \"__main__\":
    main()"""

for line in code_text.split('\n'):
    p = doc.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.LEFT
    pf = p.paragraph_format
    pf.first_line_indent = Cm(0)
    pf.line_spacing = 1.0
    pf.space_before = Pt(0)
    pf.space_after = Pt(0)
    run = p.add_run(line)
    run.font.name = 'Courier New'
    run.font.size = Pt(10)


