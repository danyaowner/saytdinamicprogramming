# ГЛАВА 2
# ════════════════════════════════════════════════════════════════════════

add_section_title('2', 'МАТЕМАТИЧЕСКАЯ МОДЕЛЬ И АЛГОРИТМ РЕШЕНИЯ ЗАДАЧИ РАСПРЕДЕЛЕНИЯ ДИЗАЙНЕРСКИХ РЕСУРСОВ')

# --- 2.1 ---
add_subsection_title('2.1', 'Постановка задачи оптимизации распределения дизайнеров по проектам')

add_body(
    'Рассмотрим следующую практическую ситуацию. Дизайн-студия получила '
    'заказы на выполнение n графических проектов. Для выполнения этих '
    'проектов студия располагает m дизайнерами, каждый из которых имеет '
    'определённую специализацию и производительность. Необходимо распределить '
    'дизайнеров между проектами таким образом, чтобы суммарная эффективность '
    '(например, суммарный доход или суммарное качество выполненных проектов) '
    'была максимальной при заданных ограничениях.'
)

add_body('Сформулируем задачу более формально.')

add_body(
    'Пусть имеется N проектов (j = 1, 2, …, N), которые необходимо выполнить. '
    'Для выполнения проектов доступно R единиц ресурса (дизайнеров). Каждый '
    'дизайнер может быть закреплён только за одним проектом в данный момент '
    'времени. Если на проект j назначено x_j дизайнеров, то эффективность '
    'выполнения этого проекта описывается функцией f_j(x_j), которая '
    'отражает доход, качество или объём выполненных работ.'
)

add_body(
    'Функция эффективности f_j(x_j) обладает следующими свойствами:'
)

add_bullet('f_j(0) = 0 — если на проект не назначено ни одного дизайнера, '
           'то эффективность равна нулю;')
add_bullet('f_j(x) — неубывающая функция, так как увеличение количества '
           'дизайнеров не должно снижать эффективность;')
add_bullet('f_j(x) может иметь нелинейный характер из-за эффекта '
           'насыщения — при добавлении большого количества дизайнеров '
           'предельная полезность каждого дополнительного специалиста '
           'снижается (закон убывающей предельной отдачи).')

add_body(
    'Требуется найти такое распределение дизайнеров между проектами, '
    'которое максимизирует суммарную эффективность:'
)

add_formula_numbered('F(x_1, x_2, ..., x_N) = Σ_{j=1}^{N} f_j(x_j) → max', '3')

add_body('при ограничениях:')

add_formula_numbered('Σ_{j=1}^{N} x_j ≤ R', '4')
add_formula_numbered('x_j ∈ {0, 1, 2, ..., R}, j = 1, 2, ..., N', '5')

add_body(
    'Таким образом, мы имеем задачу целочисленной оптимизации с '
    'аддитивным критерием и одним линейным ограничением. Данная задача '
    'является классической задачей распределения ресурсов и может быть '
    'эффективно решена методом динамического программирования.'
)

# --- 2.2 ---
add_subsection_title('2.2', 'Математическая модель задачи')

add_body(
    'Для построения математической модели задачи распределения дизайнерских '
    'ресурсов сформулируем рекуррентные соотношения в терминах динамического '
    'программирования [6].'
)

add_body(
    'Процесс распределения ресурсов разобьём на N шагов, где на каждом шаге '
    'k (k = 1, 2, …, N) принимается решение о количестве ресурсов x_k, '
    'выделяемых на проект k.'
)

add_body('Введём следующие обозначения:')

add_bullet('k — номер шага (номер проекта);')
add_bullet('s — количество ресурсов, доступных для распределения на '
           'оставшиеся проекты (состояние системы);')
add_bullet('x_k — количество дизайнеров, выделяемых на проект k '
           '(управление на шаге k);')
add_bullet('f_k(x_k) — эффективность выполнения проекта k при выделении '
           'x_k дизайнеров;')
add_bullet('F_k(s) — максимальная суммарная эффективность для проектов '
           'с k по N при условии, что на их выполнение выделено s ресурсов '
           '(функция Беллмана).')

add_body(
    'Уравнение перехода для состояния системы имеет вид:'
)

add_formula_numbered('s_{k+1} = s_k - x_k', '6')

add_body(
    'где s_k — количество ресурсов, доступное в начале k-го шага; '
    'x_k — количество ресурсов, выделенных на k-й проект. '
    'Функциональное уравнение Беллмана для данной задачи записывается '
    'следующим образом:'
)

add_formula_numbered('F_k(s) = max_{0 ≤ x_k ≤ s} { f_k(x_k) + F_{k+1}(s - x_k) }', '7')

add_body('для k = N, N-1, …, 1, с граничным условием:')

add_formula_numbered('F_{N+1}(s) = 0 для всех s = 0, 1, ..., R', '8')

add_body(
    'Рекуррентное соотношение (7) выражает принцип оптимальности Беллмана: '
    'максимальная эффективность на шагах с k по N равна максимуму по всем '
    'допустимым значениям x_k от суммы эффективности k-го проекта и '
    'максимальной эффективности оставшихся проектов при уменьшенном '
    'количестве ресурсов.'
)

add_body(
    'Граничное условие (8) означает, что после распределения всех проектов '
    '(т.е. на шаге N+1) эффективность равна нулю независимо от количества '
    'оставшихся ресурсов.'
)

add_body(
    'Решение задачи выполняется в два этапа.'
)

add_body(
    'Этап 1 (прямой ход — от последнего проекта к первому). Для каждого '
    'возможного состояния s = 0, 1, …, R последовательно вычисляются '
    'значения функций Беллмана F_k(s) и запоминаются оптимальные решения '
    'x_k^*(s). Вычисления начинаются с последнего проекта (k = N) и '
    'завершаются первым (k = 1).'
)

add_body(
    'Этап 2 (обратный ход — от первого проекта к последнему). Используя '
    'вычисленные на первом этапе значения x_k^*(s), восстанавливается '
    'оптимальная траектория распределения ресурсов. На первом шаге при '
    'начальном состоянии s = R выбирается x_1^* = x_1^*(R). Затем '
    'состояние обновляется: s = R - x_1^*, и для второго шага выбирается '
    'x_2^* = x_2^*(s), и так далее до последнего проекта.'
)

add_table(
    ['Обозначение', 'Описание'],
    [
        ['N', 'Количество проектов'],
        ['R', 'Общее количество доступных дизайнеров'],
        ['x_k', 'Количество дизайнеров, назначенных на проект k'],
        ['f_k(x_k)', 'Эффективность проекта k при выделении x_k дизайнеров'],
        ['F_k(s)', 'Максимальная суммарная эффективность проектов k…N при ресурсе s'],
        ['s', 'Состояние системы (оставшийся ресурс)'],
    ],
    caption='Таблица 1 — Обозначения, используемые в математической модели'
)

# --- 2.3 ---
add_subsection_title('2.3', 'Алгоритм решения методом динамического программирования')

add_body(
    'На основе сформулированной математической модели разработаем алгоритм '
    'решения задачи распределения дизайнерских ресурсов. Алгоритм состоит '
    'из двух основных фаз, как описано выше, и включает следующие шаги.'
)

add_paragraph('Шаг 1. Инициализация данных.', bold=True, indent=False)
add_body(
    'Задаётся количество проектов N, общее количество доступных дизайнеров R, '
    'а также функции эффективности f_k(x_k) для каждого проекта k = 1, 2, …, N '
    'и для всех возможных значений x_k = 0, 1, …, R. Функции эффективности '
    'могут быть заданы таблично или аналитически.'
)

add_paragraph('Шаг 2. Прямой ход (вычисление функций Беллмана).', bold=True, indent=False)
add_body(
    'Для k от N до 1 (с шагом -1) и для каждого s от 0 до R выполняется:'
)

add_bullet('если k = N, то F_N(s) = f_N(s), x_N^*(s) = s;')
add_bullet('если k < N, то F_k(s) = max_{0 ≤ x ≤ s} { f_k(x) + F_{k+1}(s - x) }, '
           'x_k^*(s) = arg max_{0 ≤ x ≤ s} { f_k(x) + F_{k+1}(s - x) }.')

add_body(
    'Результатом первого этапа является таблица значений функций Беллмана '
    'F_k(s) и соответствующих оптимальных решений x_k^*(s) для всех k и s.'
)

add_paragraph('Шаг 3. Обратный ход (восстановление оптимального решения).', bold=True, indent=False)
add_body(
    'Устанавливается s = R. Для k от 1 до N выполняется:'
)

add_bullet('x_k^* = x_k^*(s) — оптимальное количество дизайнеров для проекта k;')
add_bullet('s = s - x_k^* — обновление состояния.')

add_body(
    'Результатом второго этапа является оптимальный вектор распределения '
    'ресурсов (x_1^*, x_2^*, …, x_N^*), обеспечивающий максимальную '
    'суммарную эффективность.'
)

add_paragraph('Шаг 4. Вывод результатов.', bold=True, indent=False)
add_body(
    'На экран выводятся: оптимальное распределение дизайнеров по проектам, '
    'суммарная эффективность F_1(R), а также таблица значений функций '
    'Беллмана для анализа.'
)

add_body(
    'Вычислительная сложность алгоритма составляет O(N·R²), где N — '
    'количество проектов, R — количество ресурсов. Это обусловлено тем, '
    'что на каждом шаге k и при каждом состоянии s необходимо перебрать '
    'все возможные значения x от 0 до s. При больших значениях N и R '
    'время выполнения может расти квадратично, однако для большинства '
    'практических задач (N ≤ 20, R ≤ 100) алгоритм работает достаточно '
    'быстро.'
)

add_table(
    ['Шаг', 'Действие', 'Результат'],
    [
        ['1', 'Инициализация N, R, f_k(x)', 'Исходные данные'],
        ['2', 'Прямой ход: вычисление F_k(s)', 'Таблицы F_k(s) и x_k^*(s)'],
        ['3', 'Обратный ход: восстановление решения', 'Оптимальный вектор (x_1^*, …, x_N^*)'],
        ['4', 'Вывод результатов', 'Оптимальное распределение и F_1(R)'],
    ],
    caption='Таблица 2 — Этапы алгоритма динамического программирования'
)

add_page_break()


